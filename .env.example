# 复制为 .env(仓库根,同目录),填入你的 OpenAI 兼容端点凭据。
# .env 已被 .gitignore,不会提交。
#
# 格式:KEY=value,一行一个;不要写 export;value 一般不用加引号(除非含空格)。
# 两个联调脚本(scripts/e2e_real_llm.py、services/worker/scripts/smoke_openai.py)
# 会自动读取本仓库根的 .env。

AGENT_CLOUD_WORKER_OPENAI_API_KEY=sk-your-key-here
AGENT_CLOUD_WORKER_OPENAI_BASE_URL=https://www.sophnet.com/api/open-apis/v1

# 单次输出上限(可选,默认 4096)
# AGENT_CLOUD_WORKER_REQUEST_MAX_TOKENS=4096

# 仅 OpenAI 推理模型(o 系列 / gpt-5 reasoning)需要(默认 max_tokens):
# AGENT_CLOUD_WORKER_MAX_TOKENS_PARAM=max_completion_tokens

# 网络区域(可选,默认 cn=中国大陆)。cn / cn-* 时给 agent 注入"哪些站点不可达 + 搜索用
# cn.bing.com"的提示(生产在阿里云境内,连不通 google/wikipedia);海外部署设 global 关闭。
# AGENT_CLOUD_WORKER_NETWORK_REGION=cn

# web_search 工具(可选)。配了搜索 key 才把 web_search 暴露给 agent(空=不暴露)。独立于上面
# 的 LLM key:agent 可能 BYOK 别家模型,搜索走平台专用 sophnet key,不复用 LLM key。
# AGENT_CLOUD_WORKER_WEB_SEARCH_API_KEY=
# AGENT_CLOUD_WORKER_WEB_SEARCH_ENDPOINT=https://www.sophnet.com/api/open-apis/moltbot/search/web
# AGENT_CLOUD_WORKER_WEB_SEARCH_MAX_RESULTS=8

# 单回合内 LLM↔工具往返的迭代上限(可选,默认 20)。跑满即 max_iterations 收尾(回合不完整)。
# 调大允许更长的自主工具链,但最坏耗时/输出预算按倍数升;正常 end_turn 收尾的回合不受影响。
# AGENT_CLOUD_WORKER_MAX_ITERATIONS=20

# 注入 system prompt 的"今天日期"固定时区偏移(小时,可选,范围 -24~24,默认 8=北京)。模型不知
# 真实日期,给它当天日期解决查"今天/今年"瞎猜;海外按当地改(⚠️ 夏令时地区会差 1 小时)。
# AGENT_CLOUD_WORKER_TIMEZONE_OFFSET_HOURS=8

# ── 会话压缩(backend;dev_up.sh 会把根 .env export 给 backend)──
# 回合后若模型返回的真实 context_tokens 超过阈值,就把旧历史折叠成摘要。
# 全局默认阈值(可选,默认 128000;建议设为所用模型上下文窗口的 ~70-80%):
# AGENT_CLOUD_COMPACTION_TOKEN_THRESHOLD=128000
# 按模型覆盖阈值(可选,JSON;未列出的模型回退上面的全局默认)。
# 注意:JSON 含双引号,bash source .env 时【必须】用单引号整体包裹,否则内层引号会被剥掉:
# AGENT_CLOUD_COMPACTION_TOKEN_THRESHOLDS='{"DeepSeek-V4-Pro": 200000}'
# 压缩时逐字保留的最近消息条数(可选,默认 8):
# AGENT_CLOUD_COMPACTION_KEEP_RECENT=8

# ── 鉴权(backend)──
# access JWT 的 HS256 签名密钥。【生产必须设】一个长随机串(≥32 字节);默认值仅用于本地。
# AGENT_CLOUD_AUTH_SECRET=请换成长随机串-openssl-rand-base64-48
# refresh 的 cookie 是否标记 Secure(仅 https 下发)。生产(https)必须 true;本地 http 用 false。
# AGENT_CLOUD_AUTH_COOKIE_SECURE=false
# access / refresh 有效期(秒,可选):默认 900(15min)/ 2592000(30d)
# AGENT_CLOUD_ACCESS_TOKEN_TTL_SECONDS=900
# AGENT_CLOUD_REFRESH_TOKEN_TTL_SECONDS=2592000

# ── BYO-Key(backend)──
# 用户自带 LLM 凭据的 AES-GCM 主密钥(base64 的 32 字节)。空 = 凭据功能不可用(创建凭据会 500)。
# 生成:python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# AGENT_CLOUD_CREDENTIAL_KEY=

# ── 数据库密码(部署:deploy/compose.yml)──
# 【生产必须设】postgres 密码,强随机值;缺失时 docker compose 直接 fail-loud,不会用弱默认起库。
# 生成:openssl rand -base64 24。变更已有部署见 docs/security/sandbox-isolation.md §6。
# AGENT_CLOUD_DB_PASSWORD=

# ── 部署形参(deploy/compose.yml,按机器设;本地开发不用)──
# web 容器发布到宿主机的端口(默认 8080;st-e 机网关只放通 18080 则设 18080):
# AGENT_CLOUD_WEB_PORT=8080
# 单沙箱内存上限(默认 256m,适配 1.6G 小机;大内存机可放宽,如 2g):
# AGENT_CLOUD_SANDBOX_MEM_LIMIT=256m
